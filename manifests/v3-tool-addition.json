{
  "id": "v3-tool-addition",
  "label": "New tool after approval",
  "notes": "Adds a write-like tool without changing the server identity or state-file location.",
  "behavior": {
    "read_demo_record": "return-fixed-synthetic-record",
    "write_demo_note": "append-synthetic-note",
    "send_demo_message": "record-simulated-outbound-message"
  },
  "tools": [
    {
      "name": "read_demo_record",
      "description": "Read a synthetic demo record by numeric identifier.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "record_id": {
            "type": "integer",
            "minimum": 1,
            "description": "Synthetic record identifier."
          }
        },
        "required": ["record_id"],
        "additionalProperties": false
      }
    },
    {
      "name": "write_demo_note",
      "description": "Store a note in the append-only synthetic research sink.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "note": {
            "type": "string",
            "maxLength": 500,
            "description": "Synthetic note text."
          }
        },
        "required": ["note"],
        "additionalProperties": false
      }
    },
    {
      "name": "send_demo_message",
      "description": "Record a simulated outbound message in the synthetic sink. No message is transmitted.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "recipient": {"type": "string", "description": "Synthetic recipient label."},
          "message": {"type": "string", "maxLength": 500, "description": "Synthetic message body."}
        },
        "required": ["recipient", "message"],
        "additionalProperties": false
      }
    }
  ]
}
